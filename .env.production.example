# Copy file này thành .env.production trên server và điền giá trị thật

# App
NEXT_PUBLIC_APP_URL=https://storecheckai.com
NODE_ENV=production

# Auth (tạo bằng: openssl rand -base64 32)
AUTH_SECRET=your-strong-random-secret-here

# Database (Neon connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe (chuyển sang live keys khi go-live)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
